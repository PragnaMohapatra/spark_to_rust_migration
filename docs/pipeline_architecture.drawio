        </mxCell>
        <mxCell id="s11" value="&lt;b&gt;Parsed Streaming Record&lt;/b&gt;&lt;br&gt;All raw transaction fields&lt;br&gt;+ kafka_key&lt;br&gt;+ topic&lt;br&gt;+ kafka_partition&lt;br&gt;+ kafka_offset&lt;br&gt;+ kafka_timestamp" style="swimlane;html=1;startSize=30;horizontal=0;childLayout=stackLayout;rounded=0;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="450" y="260" width="230" height="250" as="geometry" />
        </mxCell>
        <mxCell id="s12" value="&lt;b&gt;Transaction Final Table&lt;/b&gt;&lt;br&gt;Original parsed fields preserved&lt;br&gt;+ currency_safe&lt;br&gt;+ risk_score_safe&lt;br&gt;+ memo_clean&lt;br&gt;+ transaction_date&lt;br&gt;+ txn_year, txn_month, txn_day&lt;br&gt;+ txn_hour, txn_dayofweek, is_weekend&lt;br&gt;+ txn_quarter, date_str&lt;br&gt;+ amount_bucket, net_amount, fee_pct&lt;br&gt;+ amount_usd, log_amount&lt;br&gt;+ risk_tier, risk_level, needs_review&lt;br&gt;+ is_cross_border, corridor, is_intra_bank&lt;br&gt;+ sender_hash, receiver_hash&lt;br&gt;+ sender_account_masked, receiver_account_masked&lt;br&gt;+ ip_anonymized&lt;br&gt;+ device_short_id, session_prefix&lt;br&gt;+ memo_length, has_memo, row_id" style="swimlane;html=1;startSize=30;horizontal=0;childLayout=stackLayout;rounded=0;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="1">
