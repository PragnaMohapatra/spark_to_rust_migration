        <mxCell id="s20" value="&lt;b&gt;Account Raw Kafka Event&lt;/b&gt;&lt;br&gt;account_id&lt;br&gt;account_number&lt;br&gt;holder_name&lt;br&gt;bank_code&lt;br&gt;country&lt;br&gt;currency&lt;br&gt;account_type&lt;br&gt;account_status&lt;br&gt;balance&lt;br&gt;total_sent&lt;br&gt;total_received&lt;br&gt;transaction_count&lt;br&gt;risk_rating&lt;br&gt;kyc_level&lt;br&gt;last_transaction_time&lt;br&gt;updated_at&lt;br&gt;created_at" style="swimlane;html=1;startSize=30;horizontal=0;childLayout=stackLayout;rounded=0;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="1">
