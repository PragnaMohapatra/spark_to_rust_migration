        <mxCell id="t1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;" value="&lt;font style=&quot;font-size:24px;&quot;&gt;&lt;b&gt;Transaction Transformations&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Applies equally to Spark and Rust transaction pipelines" vertex="1">
          <mxGeometry height="60" width="980" x="610" y="260" as="geometry" />
        </mxCell>
        <mxCell id="t2" parent="1" style="shape=document;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;b&gt;Raw Parsed Transaction Record&lt;/b&gt;&lt;br&gt;Kafka metadata + 27 business fields" vertex="1">
          <mxGeometry height="100" width="260" x="80" y="360" as="geometry" />
        </mxCell>
        <mxCell id="t3" parent="1" style="shape=document;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Final Enriched Transaction Record&lt;/b&gt;&lt;br&gt;Original fields preserved&lt;br&gt;+ 27 derived analytics columns" vertex="1">
          <mxGeometry height="100" width="270" x="1820" y="360" as="geometry" />
        </mxCell>
        <mxCell id="t10" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T1 Null Handling&lt;/b&gt;&lt;br&gt;Purpose: make downstream logic null-safe&lt;br&gt;&lt;br&gt;Logic:&lt;br&gt;- currency_safe = coalesce(currency, USD)&lt;br&gt;- risk_score_safe = coalesce(risk_score, 0.0)&lt;br&gt;- memo_clean = trim(memo) or (no memo)&lt;br&gt;- fee default 0.0&lt;br&gt;- exchange_rate default 1.0&lt;br&gt;- sender_country / receiver_country default XX" vertex="1">
          <mxGeometry height="150" width="250" x="380" y="335" as="geometry" />
        </mxCell>
        <mxCell id="t11" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T2 Time Dimensions&lt;/b&gt;&lt;br&gt;Purpose: partitioning and time analytics&lt;br&gt;&lt;br&gt;Adds:&lt;br&gt;- transaction_date&lt;br&gt;- txn_year, txn_month, txn_day&lt;br&gt;- txn_hour, txn_dayofweek&lt;br&gt;- is_weekend&lt;br&gt;- txn_quarter&lt;br&gt;- date_str" vertex="1">
          <mxGeometry height="150" width="250" x="670" y="335" as="geometry" />
        </mxCell>
        <mxCell id="t12" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T3 Amount Features&lt;/b&gt;&lt;br&gt;Purpose: monetary analytics&lt;br&gt;&lt;br&gt;Adds:&lt;br&gt;- amount_bucket by thresholds&lt;br&gt;- net_amount = amount - fee&lt;br&gt;- fee_pct&lt;br&gt;- amount_usd = amount * exchange_rate&lt;br&gt;- log_amount" vertex="1">
          <mxGeometry height="150" width="250" x="960" y="335" as="geometry" />
        </mxCell>
        <mxCell id="t13" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T4 Risk Features&lt;/b&gt;&lt;br&gt;Purpose: risk classification and review routing&lt;br&gt;&lt;br&gt;Adds:&lt;br&gt;- risk_tier&lt;br&gt;- risk_level&lt;br&gt;- needs_review = risk_score &gt;= 0.7 or is_flagged or amount &gt;= 100000" vertex="1">
          <mxGeometry height="150" width="250" x="1250" y="335" as="geometry" />
        </mxCell>
        <mxCell id="t14" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T5 Geo Features&lt;/b&gt;&lt;br&gt;Purpose: corridor and bank movement analysis&lt;br&gt;&lt;br&gt;Adds:&lt;br&gt;- is_cross_border&lt;br&gt;- corridor = sender_country -&gt; receiver_country&lt;br&gt;- is_intra_bank" vertex="1">
          <mxGeometry height="150" width="250" x="540" y="570" as="geometry" />
        </mxCell>
        <mxCell id="t15" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T6 Anonymization&lt;/b&gt;&lt;br&gt;Purpose: analytics-safe output and PII masking&lt;br&gt;&lt;br&gt;Adds:&lt;br&gt;- sender_hash, receiver_hash&lt;br&gt;- sender_account_masked&lt;br&gt;- receiver_account_masked&lt;br&gt;- ip_anonymized" vertex="1">
          <mxGeometry height="150" width="250" x="910" y="570" as="geometry" />
        </mxCell>
        <mxCell id="t16" parent="1" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="&lt;b&gt;T7 Session Features&lt;/b&gt;&lt;br&gt;Purpose: device/session analytics&lt;br&gt;&lt;br&gt;Adds:&lt;br&gt;- device_short_id&lt;br&gt;- session_prefix&lt;br&gt;- memo_length&lt;br&gt;- has_memo&lt;br&gt;- row_id = sha256(transaction_id)" vertex="1">
          <mxGeometry height="150" width="250" x="1280" y="570" as="geometry" />
        </mxCell>
        <mxCell id="t20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;b&gt;Spark Implementation&lt;/b&gt;&lt;br&gt;spark_jobs/transforms.py&lt;br&gt;apply_all_transforms uses .transform() chain&lt;br&gt;Built-ins: withColumn, when, coalesce, sha2, regexp_replace&lt;br&gt;UDFs: classify_risk, mask_account" vertex="1">
          <mxGeometry height="140" width="470" x="420" y="860" as="geometry" />
